<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Booksy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/booksy.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom mb-3">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Book" asp-action="Index">Booksy</a>
            <div class="navbar-nav me-auto">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a class="nav-link" asp-controller="Book" asp-action="Index">Overzicht</a>
                    <a class="nav-link" asp-controller="Book" asp-action="Create">Nieuw Boek</a>
                }
            </div>
            <div class="navbar-nav">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="nav-link">Ingelogd als @User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-link nav-link">Uitloggen</button>
                    </form>
                }
                else
                {
                    <a class="nav-link" asp-controller="Account" asp-action="Login">Inloggen</a>
                    <a class="nav-link" asp-controller="Account" asp-action="Register">Registreren</a>
                }
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <footer class="booksy-footer text-center mt-5 mb-4">
        <div class="container">Booksy &middot; @System.DateTime.Now.Year</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
