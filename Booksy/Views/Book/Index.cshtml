@model IEnumerable<Booksy.ViewModels.BookViewModel>

@{
    ViewData["Title"] = "Boekenoverzicht";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h1>Mijn Boeken</h1>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">Nieuw Boek Toevoegen</a>
        </div>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>Titel</th>
                <th>Auteur</th>
                <th>Genres</th>
                <th>Leesstatus</th>
                <th>Acties</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Author</td>
                    <td>
                        @foreach (var genre in item.GenreNames)
                        {
                            <span class="badge bg-secondary me-1">@genre</span>
                        }
                    </td>
                    <td><span class="badge bg-info text-dark">@item.ReadingStatus</span></td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.BookID">Details</a> |
                        <a asp-action="Edit" asp-route-id="@item.BookID">Bewerken</a> |
                        <a asp-action="Delete" asp-route-id="@item.BookID">Verwijderen</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
