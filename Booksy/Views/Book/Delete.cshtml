@model Booksy.ViewModels.BookViewModel

@{
    ViewData["Title"] = "Boek Verwijderen";
}

<div class="container mt-4">
    <h1>Verwijderen</h1>

    <h3 class="text-danger">Weet je zeker dat je dit wilt verwijderen?</h3>
    <div>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">Titel</dt>
            <dd class="col-sm-10">@Model.Name</dd>
            
            <dt class="col-sm-2">Auteur</dt>
            <dd class="col-sm-10">@Model.Author</dd>
        </dl>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="BookID" />
            <input type="submit" value="Verwijderen" class="btn btn-danger" /> |
            <a asp-action="Index">Terug naar lijst</a>
        </form>
    </div>
</div>
