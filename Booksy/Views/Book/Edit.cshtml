@model Booksy.ViewModels.BookViewModel

@{
    ViewData["Title"] = "Boek Bewerken";
}

<div class="container mt-4">
    <h1>Boek Bewerken</h1>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="BookID" />
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Titel</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Author" class="form-label">Auteur</label>
                    <input asp-for="Author" class="form-control" />
                    <span asp-validation-for="Author" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Genres" class="form-label">Genres</label>
                    <input asp-for="Genres" class="form-control" placeholder="bijv. Roman, Thriller" />
                    <small class="text-muted">Meerdere genres scheiden met een komma.</small>
                    <span asp-validation-for="Genres" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ReadingStatus" class="form-label">Leesstatus</label>
                    <select asp-for="ReadingStatus" class="form-select">
                        <option value="Wil ik lezen">Wil ik lezen</option>
                        <option value="Bezig">Bezig</option>
                        <option value="Gelezen">Gelezen</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="CoverImage" class="form-label">Omslagafbeelding (URL)</label>
                    <input asp-for="CoverImage" class="form-control" placeholder="https://..." />
                    <small class="text-muted">Laat leeg voor een standaardafbeelding.</small>
                </div>
                <div class="mb-3">
                    <input type="submit" value="Opslaan" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
