namespace Booksy.Views.Home
@model Booksy.Models.Boek

<h2>Boekdetails</h2>

<p><strong>Titel:</strong> @Model.Naam</p>
<p><strong>Auteur:</strong> @Model.Auteur</p>
<p><strong>Genre:</strong> @Model.Genre</p>

<div style="max-width:500px; margin:60px auto;">
    <a href="/Home/Boekenoverzicht" style="color:gray;">← Terug naar overzicht</a>

    <h2 style="margin-top:24px;">@Model.Naam</h2>

    <div style="margin-top:24px; display:flex; flex-direction:column; gap:12px;">
        <p><strong>Auteur:</strong> @Model.Auteur</p>
        <p><strong>Genre:</strong> @Model.Genre</p>
    </div>
</div>