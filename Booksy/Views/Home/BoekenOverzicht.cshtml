namespace Booksy.Views.Home
@model List<Booksy.Models.Boek>

<h2>Mijn boeken</h2>

@if (Model.Count == 0)
{
    <p>Geen boeken gevonden.</p>
}
else
{
    <table>
        <tr>
            <th>Titel</th>
            <th>Auteur</th>
            <th>Genre</th>
        </tr>
        @foreach (var boek in Model)
        {
            <tr>
                <td>@boek.Naam</td>
                <td>@boek.Auteur</td>
                <td>@boek.Genre</td>
            </tr>
        }
    </table>
    @foreach (var boek in Model)
    {
        <tr>
            <td><a href="/Home/BoekDetails/@boek.BoekID">@boek.Naam</a></td>
            <td>@boek.Auteur</td>
            <td>@boek.Genre</td>
        </tr>

{
    ViewData["Title"] = "Mijn boeken";
}

<div style="max-width:800px; margin:60px auto;">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <h2>Mijn boeken</h2>
        <a href="/Home/BoekToevoegen">
            <button style="padding:10px 20px; cursor:pointer;">+ Boek toevoegen</button>
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <p style="color:gray; margin-top:24px;">Geen boeken gevonden.</p>
    }
    else
    {
        <table style="width:100%; border-collapse:collapse; margin-top:24px;">
            <tr style="border-bottom:2px solid #ddd;">
                <th style="text-align:left; padding:10px;">Titel</th>
                <th style="text-align:left; padding:10px;">Auteur</th>
                <th style="text-align:left; padding:10px;">Genre</th>
            </tr>
            @foreach (var Boek in Model)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td style="padding:10px;">
                        <a href="/Home/BoekDetails/@boek.BoekID">@boek.Naam</a>
                    </td>
                    <td style="padding:10px;">@boek.Auteur</td>
                    <td style="padding:10px;">@boek.Genre</td>
                </tr>
            }
        </table>
    }
</div>
    }
}
